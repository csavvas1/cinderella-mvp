engine-strict=false
fund=false
audit=false
# pnpm 11 adds a default minimum-release-age gate that rejects freshly
# published deps (e.g. same-day Supabase releases). Disable it so installs
# resolve against the committed lockfile without waiting out the cooldown.
minimumReleaseAge=0
# force the PUBLIC npm registry — otherwise the machine's corporate proxy
# (artifactory.corp.xtb.com) gets baked into the lockfile and Vercel can't reach it
registry=https://registry.npmjs.org/
