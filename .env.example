# Copy to .env and fill with your Supabase project values.
# Only the URL + anon/publishable key belong here (safe for the frontend).
# NEVER put the service/secret key in this file or any frontend env.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key
